{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "encode-lab",
  "version": "0.1.0",
  "identifier": "com.igmainc.encode-lab",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "encode-lab",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$VIDEO/**", "$TEMP/**", "$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMjAxQkNBN0JDOEJDQjYKUldTMnZNaDd5aHNnY1JzSSsxM1dTQTR6SFpEKzlRNHFGRTZmaGUvZVU0UVVJMnpGWVNLeVFNS1IK",
      "endpoints": [
        "https://github.com/iGmainC/encode-lab/releases/latest/download/latest.json"
      ]
    }
  }
}
